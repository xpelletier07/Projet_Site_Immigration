    {
      "name": "🔐 Authentification",
      "item": [
        {
          "name": "Créer un compte Client",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.id_client) {",
                  "  pm.collectionVariables.set('CLIENT_ID', json.id_client);",
                  "}",
                  "",
                  "pm.test(\"Le status code est 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "",
                  "pm.test(\"La réponse est du JSON\", function () {",
                  "    pm.response.to.be.json;",
                  "});",
                  "",
                  "pm.test(\"Le body contient un token\", function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property(\"token\");",
                  "    pm.expect(json.token).to.be.a(\"string\").and.not.empty;",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nom\": \"Tremblay\",\n  \"prenom\": \"Alice\",\n  \"courriel\": \"alice.tremblay@exemple.com\",\n  \"telephone\": \"5141234567\",\n  \"MDP\": \"MotDePasse123!\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{BASE_URL}}/auth/create/Client",
              "host": [
                "{{BASE_URL}}"
              ],
              "path": [
                "auth",
                "create",
                "Client"
              ]
            },
            "description": "Crée un nouveau compte client. Retourne l'id_client créé."
          },
          "response": []
        },
